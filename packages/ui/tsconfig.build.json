{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2019", "DOM"],
    "noEmit": false,
    "target": "ES2019",
    "moduleResolution": "Node",
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": true,
    "outDir": "dist/temp-types"
  },
  "include": [
    "src",
    "env.d.ts"
  ],
  "exclude": [
    "**/*.spec.ts"
  ]
}
