{
  "extends": "../../tsconfig.base.json",
  "include": ["src", "env.d.ts", "tests", "vitest.config.ts"],
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "types": ["vitest/globals"]
  },
  "vueCompilerOptions": {
    "strictTemplates": false
  }
}
