{
  "name": "core",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:all": "npm run build:jit && npm run build:lib && npm run build:docs",
    "build:lib": "pnpm run -r build-lib",
    "build:jit": "pnpm run -r build-jit",
    "build:docs": "pnpm run -r build:docs",
    "build:play": "pnpm run -r build-play",
    "dev:play": "pnpm run -r dev:play",
    "dev": "pnpm run -r dev:play & pnpm run -r dev:docs",
    "dev:docs": "pnpm run -r dev:docs",
    "test:lib": "pnpm run -r test:lib",
    "test:jit": "pnpm run -r test:jit",
    "test": "pnpm run test:lib && pnpm run test:jit",
    "preview:docs": "pnpm run -r preview:docs",
    "lint:lib": "pnpm run -r lint:lib",
    "lint:jit": "pnpm run -r lint:jit",
    "typecheck": "pnpm run -r typecheck",
    "lint": "eslint --ext .js,.ts,.vue .",
    "lint:fix": "eslint --fix --ext .js,.ts,.vue .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build:jit && pnpm run build:lib && changeset publish",
    "pre:alpha": "changeset pre enter alpha",
    "pre:beta": "changeset pre enter beta",
    "pre:rc": "changeset pre enter rc",
    "pre:exit": "changeset pre exit"

  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.3.0",
    "json": "^11.0.0",
    "lerna": "^9.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
